<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %F:%L - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Silence noisy Spring/Hibernate internals -->
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.flywaydb" level="INFO"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>

    <!-- Our code at DEBUG so all log.info/warn/error show -->
    <logger name="com.inhouse.llmqueue" level="DEBUG"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
